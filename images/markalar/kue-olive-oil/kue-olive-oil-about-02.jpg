    {{/if}}
    <div class="examineIcon tip detailLink" title="{{translate 'UrunListesi_UrunuIncele'}}">
        <a href='{{url}}' class="detailUrl" data-id="{{productId}}">
            {{translate 'UrunListesi_UrunuIncele'}}
        </a>
