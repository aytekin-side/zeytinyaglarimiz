<script type="text/javascript">
    var pageContentId;

    
    var sayfaIcerikUrunler = [];

    function getOnerilenUrunler(filterModel) {
        ticimaxApi.product.getProductList({ FilterJson: JSON.stringify(filterModel.filter), PagingJson: JSON.stringify(filterModel.paging) }, function (response) {

            sayfaIcerikUrunler.pushArray(response.products);
            if (sayfaIcerikUrunler.length > 0) {
                getSayfaIcerikUrunCompleted();
                $('#divIcerikUrunleri').show();
            }
        });
    };

    function getSayfaIcerikUrunCompleted() {
        var element = $('.IcerikUrunleri[init=false]:eq(0)');
        var source1 = $("#scriptTemplateIcerikUrunleri").html();
        var template1 = Handlebars.compile(source1);
        element.attr("init", "true");
        var urunlerContainer = { products: sayfaIcerikUrunler };
        $(element).find('.ulUrunSlider').html(template1(urunlerContainer));
        setTimeout(function () {
            if (typeof urunListCallback != "undefined")
                urunListCallback();
            lazyLoad();
        }, 100);
    }
    
    $(document).ready(function () {
        var sayfaIcerikUrunler = createProductFilterModel();
        sayfaIcerikUrunler.filter.PageContentId = pageContentId;
        sayfaIcerikUrunler.paging.PageItemCount = 30;
        getOnerilenUrunler(sayfaIcerikUrunler);
        
    });
    
</script>


<main id="main" style="box-sizing:border-box; outline:none !important; display:block; color:#202020; font-family:karla, sans-serif; font-size:12px; font-style:normal; font-variant-ligatures:normal; font-variant-caps:normal; font-weight:400; letter-spacing:normal; orphans:2; text-align:left; text-indent:0px; text-transform:none; white-space:normal; widows:2; word-spacing:0px; -webkit-text-stroke-width:0px; text-decoration-thickness:initial; text-decoration-style:initial; text-decoration-color:initial">
<div class="container" style="width:1212px; padding-right:10px; padding-left:10px; max-width:1212px"><span style="box-sizing:border-box"><span style="outline:none !important">
<div class="row" style="margin-right:-10px; margin-left:-10px"><span style="box-sizing:border-box"><span style="outline:none !important"><span style="display:flex"><span style="flex-wrap:wrap"></span></span></span></span>
<section class="col-12" style="box-sizing:border-box; outline:none !important; display:block; position:relative; width:1212px; min-height:1px; padding-right:10px; padding-left:10px; flex:0 0 100%; max-width:100%"><span style="box-sizing:border-box"><span style="outline:none !important"><span style="display:flex"><span style="flex-wrap:wrap">
<div class="contentbox-body"><span style="font-size:14px"><span style="box-sizing:border-box"><span style="outline:none !important"><span style="line-height:24px">
<div class="row" style="margin-right:-10px; margin-left:-10px"><span style="box-sizing:border-box"><span style="outline:none !important"><span style="display:flex"><span style="flex-wrap:wrap">
<div class="col-12" style="width:1212px; padding-right:10px; padding-left:10px; max-width:100%"><span style="box-sizing:border-box"><span style="outline:none !important"><span style="position:relative"><span style="min-height:1px"><span style="flex:0 0 100%">
<p style="text-align: center;"><img alt="" src="https://static.ticimax.cloud/56736/uploads/editoruploads/edebiyat-ve-zeytin.jpg" /></p>

<p style="text-align: center;"><span style="font-size:26px;"><span style="font-family:Times New Roman,Times,serif;"><strong>KAZ DAĞLARINDAN SOFRANIZA GELEN BİR LEZZET SERÜVENİ...</strong></span></span></p>

<p style="text-align:justify">&nbsp;</p>

<p style="text-align:justify"><span style="font-size:12pt"><span style="box-sizing:border-box"><span style="outline:none !important"><span style="font-family:&quot;Times New Roman&quot;, serif">Kaz Dağları bölgesinden elde edilen zeytinyağları, sahip oldukları kalite özellikleriyle, hem yurt içinde hem yurt dışında haklı bir üne sahiptir. Yörenin hâkim zeytin çeşidinin yağ oranı çok yüksektir. Çeşit özelliklerinin yanı sıra, yörenin coğrafi konumunun, toprak yapısının ve esen hâkim rüzgârların, burada üretilen zeytinyağının kalite özelliklerine doğrudan etkisi vardır.</span></span></span></span><br style="box-sizing:border-box; outline:none !important" />
&nbsp;</p>

<p style="text-align:justify"><span style="font-size:12pt"><span style="box-sizing:border-box"><span style="outline:none !important"><span style="font-family:&quot;Times New Roman&quot;, serif">Bölge'nin zeytinyağını farklı kılan etmen, toprağın mineral yapısının klorofil ile buluşan elverişli fotosentezi, Ege Denizi ve Kaz Dağları ile yaratılan hava akımları ile arasındaki olgunlaşma devresi sırasında kıvam yoğunluğunu mümkün kılan 5-6 derecelik ısının don ve kırağıyı önlemesi burada üretilen zeytinyağının kalitesine doğrudan etki etki eden faktörlerdir. &nbsp;</span></span></span></span></p>

<p style="text-align:justify"><span style="font-size:12pt"><span style="box-sizing:border-box"><span style="outline:none !important"><span style="font-family:&quot;Times New Roman&quot;, serif">&nbsp;</span></span></span></span></p>

<p style="text-align:justify"><span style="font-size:12pt"><span style="box-sizing:border-box"><span style="outline:none !important"><span style="font-family:&quot;Times New Roman&quot;, serif">Bölge faktörleri nedeniyle zeytinyağında ortalama 1 yıl olan dayanıklılık süresi bu yörenin yağlarında 18-24 aya çıkar.</span></span></span></span></p>

<p style="text-align:justify"><span style="font-size:12pt"><span style="box-sizing:border-box"><span style="outline:none !important"><span style="font-family:&quot;Times New Roman&quot;, serif">&nbsp;</span></span></span></span></p>

<p style="text-align:justify"><span style="font-size:12pt"><span style="box-sizing:border-box"><span style="outline:none !important"><span style="font-family:&quot;Times New Roman&quot;, serif">Bölgede üretilen zeytinyağının önemli bir bölümü "Naturel Sızma" sınıfındadır. Duyusal özellikler bakımından, meyve aroması ve nefaseti kuvvetlidir. Sızma zeytinyağı, özel üretim hatlarında doğal özelliklerini değiştirmeyecek yöntemlerle toplandıktan sonra 24 saat içerisinde sıkılarak elde edilir.Sahip olduğu olumlu duyusal ve kimyasal özellikleri ürünün kalitesini uzun süre (yaklaşık 18-24 ay) korumasını sağlar. Kaz Dağları etekleri, Dünya'nın en lezzetli zeytinyağlarının üretildiği yerlerden biridir.</span></span></span></span></p>

<p style="text-align:justify"><span style="font-size:12pt"><span style="box-sizing:border-box"><span style="outline:none !important"><span style="font-family:&quot;Times New Roman&quot;, serif">&nbsp;</span></span></span></span></p>

<p style="text-align:justify"><span style="font-size:12pt"><span style="box-sizing:border-box"><span style="outline:none !important"><span style="font-family:&quot;Times New Roman&quot;, serif">Bu bölgenin düşük asitli ve kendine has güzel kokulu zeytinyağları, farklı bir aromaya sahiptir. Bölge zeytinlerinin zengin organoleptik yapısı yüzyıllardır bilinmektedir. Zeytinyağını kokladığınızda taze biçilmiş çimen, yeşil elma, domatesin sapındaki yeşil dal kokularını alabilirsiniz. Dünya da en kaliteli zeytinyağlarının üretildiği&nbsp; Kaz Dağları etekleri ülkemizin göz bebeğidir.</span></span></span></span></p>

<p style="text-align:justify"><span style="font-size:12pt"><span style="box-sizing:border-box"><span style="outline:none !important"><span style="font-family:&quot;Times New Roman&quot;, serif">&nbsp;</span></span></span></span></p>

<p style="text-align:justify"><span style="font-size:12pt"><span style="box-sizing:border-box"><span style="outline:none !important"><span style="font-family:&quot;Times New Roman&quot;, serif">Dünyanın en kaliteli ve lezzetli zeytinyağının üretildiği kuzey Kaz Dağları bölgesinde bütün bölge tarım arazisinin %90'ı zeytinliktir. Yörede zeytinyağı, hem geleneksel yöntemlerden olan Taş Baskı yöntemi hem de Modern yöntemler ile kimyasal katkı maddeleri kullanılmadan elde edilmektedir.</span></span></span></span></p>

<p style="text-align:justify">&nbsp;</p>

<p style="text-align:justify"><strong><span style="font-size:12pt"><span style="box-sizing:border-box"><span style="outline:none !important"><span style="font-family:&quot;Times New Roman&quot;, serif">KAZDAĞLARI 1915 UĞURLU ZEYTİNYAĞLARI&nbsp;&nbsp;olarak önceliğimiz;</span></span></span></span></strong></p>

<p style="text-align:justify">&nbsp;</p>

<p><span style="font-size:16px;"><span style="font-family:Times New Roman,Times,serif;"><strong>Güvenilirlik</strong>: Sağlık, kalite ve hijyeni maksimum seviyede tutarak güvenilirliği baki kılmak,</span></span></p>

<p>&nbsp;</p>
<span style="font-size:16px;"><span style="font-family:Times New Roman,Times,serif;">
<p><strong>Müşteri Odaklılık</strong>: Müşteri beklentilerini doğru ve yerinde analiz ederek; kaliteli ve ihtiyaca yönelik ürün sunmak,</p>

<p>&nbsp;</p>
</span></span></span></span></span></span><span style="font-size:16px;"><span style="font-family:Times New Roman,Times,serif;"><strong>Sürdürülebilirlik</strong>: Ölçülebilir hedefler koyarak sürekli iyileşme ve geliştirmeyi amaç edinmiş sürdürülebilir üretici bir marka olmak.</span></span></span></div>
</span></span></span></span></div>
</span></span></span></span></div>
</span></span></span></span></section>
</div>
</span></span></div>
</main>
<br />
&nbsp;

