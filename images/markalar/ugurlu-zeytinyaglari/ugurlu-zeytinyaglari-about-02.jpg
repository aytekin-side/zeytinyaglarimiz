    <div class="footerCenter">
        <style type="text/css">.ticiFooterContent ul { margin: 0; padding: 0; }
    .ticiFooterContent * { -webkit-box-sizing: border-box; -moz-box-sizing: border-box; box-sizing: border-box; }
